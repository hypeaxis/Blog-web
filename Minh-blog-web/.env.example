# NextAuth / OAuth
NEXTAUTH_URL="https://your-vercel-domain.vercel.app"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Optional: Vercel Blob persistence (recommended for production)
# If not set, posts are stored in memory and will not persist across serverless instances.
BLOB_READ_WRITE_TOKEN="replace-with-vercel-blob-token"
